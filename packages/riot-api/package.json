{
  "name": "@riftlens/riot-api",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./utils/season": "./src/utils/season.ts",
    "./utils/rank": "./src/utils/rank.ts",
    "./utils/session": "./src/utils/session.ts",
    "./utils/tags": "./src/utils/tags.ts",
    "./utils/previously-played": "./src/utils/previously-played.ts"
  },
