{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RiftLens",
  "version": "0.1.0",
  "identifier": "app.riftlens.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RiftLens",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "RiftLens Overlay",
        "url": "/desktop/overlay",
        "width": 226,
        "height": 600,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false
      },
      {
        "label": "champ-select",
        "title": "RiftLens Champ Select",
        "url": "/desktop/champ-select",
        "width": 800,
        "height": 600,
        "resizable": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
