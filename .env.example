# Better Auth
BETTER_AUTH_SECRET=           # openssl rand -base64 32
BETTER_AUTH_URL=              # https://riftlens.app (prod) | http://localhost:3000 (dev)

# Supabase — PostgreSQL + Storage only (Better Auth handles sessions)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # Storage (avatars) only

# Riot Games API — Season 2 2026
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_DEFAULT_REGION=EUW1
# Dev key: 20 req/s · 100 req/2min

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RiftLens
NEXT_PUBLIC_CURRENT_SEASON=Saison 2 2026
NEXT_PUBLIC_SEASON_START_MS=1777420800000

# OAuth providers (optional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Desktop signing (CI/CD only)
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
